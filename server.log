**Custom Dataset**

Let's assume our dataset consists of two classes: `positive` and `negative`. We'll create a custom dataset class to load and preprocess the data.
```python
import torch
from torch.utils.data import Dataset, DataLoader

class TextDataset(Dataset):
    def __init__(self, data_dir, batch_size):
        self.data_dir = data_dir
        self.batch_size = batch_size
        self.texts = []
        self.labels = []

        # Load and preprocess text data
        with open(data_dir + '/positive.txt', 'r') as f:
            for line in f:
                self.texts.append(line.strip())
                self.labels.append(1)

        with open(data_dir + '/negative.txt', 'r') as f:
            for line in f:
                self.texts.append(line.strip())
                self.labels.append(-1)

    def __len__(self):
        return len(self.texts)

    def __getitem__(self, idx):
        text = self.texts[idx]
        label = self.labels[idx]

        # Tokenize and pad text
        inputs = tokenizer(text, return_tensors='pt')

        return {
            'input_ids': inputs['input_ids'].flatten(),
            'attention_mask': inputs['attention_mask'].flatten(),
            'labels': torch.tensor(label)
        }
```
